rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public landing-page stats: aggregate counts only (population/households/etc),
    // never raw records — readable by anyone, writable only by logged-in app users
    // (the admin/supervisor dashboard keeps it fresh whenever Overview renders).
    match /public/stats {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
